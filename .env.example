# Steam Settings
STEAM_LIBRARY_PATH=/path/to/steamapps

# SeaweedFS (Storage) Settings
SEAWEEDFS_S3_ENDPOINT_URL=http://localhost:8333
SEAWEEDFS_ACCESS_KEY=your_access_key
SEAWEEDFS_SECRET_KEY=your_secret_key
SEAWEEDFS_BUCKET=sst-sounds

# MusicBrainz Settings (Rate limiting identification)
USER_AGENT=SteamSoundtrackTagger-Scout/0.1.0 ( your@email.com )

# AcoustID
ACOUSTID_API_KEY="your_acoustid_api_key_here"

# LLM Configuration (Phase 3)
LLM_MODEL="gemini/gemini-1.5-pro-latest"
# Set the corresponding API Key depending on your model choice
GEMINI_API_KEY="your_gemini_api_key_here"
# OPENAI_API_KEY="your_openai_api_key_here"

# For OpenAI API-compatible local/remote servers (e.g., vLLM, LM Studio, Ollama via OpenAI proxy)
# Uncomment and set the base URL. Use LLM_MODEL="openai/<model_name>"
# OPENAI_BASE_URL="http://localhost:8000/v1"
# OPENAI_API_KEY="dummy_key_if_unauthenticated"

# Language Priority Strategy
TARGET_LANGUAGE="ja" # Priority: 1. This Config, 2. English (en), 3. Original

# Prefect Specific Settings (Optional, can be used for explicit configuring)
PREFECT_API_URL=http://127.0.0.1:4200/api
